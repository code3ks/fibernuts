# fibernuts mint — copy this to `.env` and fill in the TWO values below.
# Everything else is detected or generated for you. Keep `.env` private (it's gitignored).

# ── 1. Your domain ────────────────────────────────────────────────────────────
# A domain (or subdomain) you own, with a DNS A record pointing at THIS server's IP.
# It becomes your mint's address — wallets connect to https://<this>. Caddy gets the
# TLS cert for it automatically. You buy/own this; there's nothing to look up.
MINT_DOMAIN=mint.example.com

# ── 2. The mint's mnemonic (its master key) ───────────────────────────────────
# A 12-word BIP-39 phrase. It seeds every signing key, so BACK IT UP offline and never
# change it. Generate one with:
#   docker run --rm python:3.12-slim sh -c "pip -q install mnemonic && python -c 'from mnemonic import Mnemonic;print(Mnemonic(\"english\").generate(128))'"
MINT_MNEMONIC="paste your twelve word phrase here"

# ── That's it. Below are OPTIONAL overrides you normally leave commented out. ──
# The server's public IP is auto-detected; only set this if detection is blocked
# (e.g. behind a proxy that hides the real IP):
# PUBLIC_IP=203.0.113.10
#
# The node's key-encryption password is auto-generated and persisted; only set this
# if you want to control it yourself:
# FIBER_SECRET_KEY_PASSWORD=some-strong-random-string
#
# A friendly name announced to the Fiber network:
# MINT_NODE_NAME=fibernuts-mint
